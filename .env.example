# Alpha-Quant-Copilot 环境变量配置示例
# 复制此文件为 .env.local 并填入真实值

# ============================================
# 1. 鉴权体系 (Clerk)
# ============================================

# 从Clerk仪表板获取: https://dashboard.clerk.com
# 开发环境使用测试密钥，生产环境使用实时密钥
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 从Clerk仪表板获取: Webhooks → 添加webhook → 复制Secret
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# 2. 数据库 (Supabase + Prisma)
# ============================================

# 业务连接池 URL (用于代码中查询数据)
DATABASE_URL="postgresql://username:password@host:6543/database?pgbouncer=true"

# 直连 URL (用于 Prisma 初始化建表/迁移)
DIRECT_URL="postgresql://username:password@host:5432/database"

# ============================================
# 3. AI 引擎
# ============================================

# DeepSeek API密钥: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AI推理代理配置（前端使用）
NEXT_PUBLIC_DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AI推理代理功能开关
NEXT_PUBLIC_AI_INFERENCE_ENABLED=true

# AI推理超时设置（毫秒）
NEXT_PUBLIC_AI_INFERENCE_TIMEOUT=30000

# AI推理重试次数
NEXT_PUBLIC_AI_INFERENCE_MAX_RETRIES=3

# AI推理缓存时间（毫秒）
NEXT_PUBLIC_AI_INFERENCE_CACHE_TTL=60000

# ============================================
# 4. 数据感知
# ============================================

# 新浪/腾讯财经API无需Token，直接使用

# ============================================
# 5. 可选配置
# ============================================

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# 应用环境: development, production
NODE_ENV=development

# 端口配置
PORT=3000

# CORS配置 (生产环境需要限制)
NEXT_PUBLIC_API_URL=http://localhost:3000

# ============================================
# 配置说明:
# ============================================
# 1. 开发环境:
#    - 复制此文件为 .env.local
#    - 填入开发环境的真实值
#
# 2. 生产环境:
#    - 创建 .env.production
#    - 使用生产环境的真实值
#    - 确保密钥安全，不要提交到版本控制
#
# 3. 安全建议:
#    - 定期轮换密钥
#    - 使用密钥管理服务
#    - 限制API访问权限
# ============================================