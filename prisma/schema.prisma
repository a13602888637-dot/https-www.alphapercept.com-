generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(cuid())
  clerkUserId       String             @unique
  email             String?
  username          String?
  firstName         String?
  lastName          String?
  imageUrl          String?
  metadata          Json?
  settings          Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  intelligenceFeeds IntelligenceFeed[]
  watchlists        Watchlist[]
  portfolios        Portfolio[]
  watchlistGroups   WatchlistGroup[]
  backtestResults   BacktestResult[]
  posts             Post[]
  comments          Comment[]
  postLikes         PostLike[]

  @@index([clerkUserId])
  @@index([email])
  @@index([username])
  @@index([createdAt])
}

model Watchlist {
  id            String   @id @default(cuid())
  userId        String
  stockCode     String
  stockName     String
  buyPrice      Decimal?
  stopLossPrice Decimal?
  targetPrice   Decimal?
  notes         String?

  // Stop-loss method and params
  stopLossMethod  String?   // "atr" | "chandelier" | "ma" | "fixed"
  stopLossParams  Json?     // { atrMultiplier: 3, atrPeriod: 14, maPeriod: 20 }

  // Take-profit method and params
  takeProfitMethod String?  // "trailing" | "atr_multiple" | "fixed"
  takeProfitParams Json?    // { trailPercent: 5, atrMultiple: 3 }

  // Dynamic tracking
  highWaterMark    Decimal? // highest price since buy (for trailing stop)
  lastComputedAt   DateTime? // when SL/TP was last computed
  computeStatus    String?  // "live" | "low_freq" | "cached" | "awaiting_data"
  cachedAtr        Decimal? // cached ATR value for fallback
  dataFrequency    String?  // "daily" | "weekly" | "monthly"

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stockCode])
  @@index([userId])
  @@index([stockCode])
}

model IntelligenceFeed {
  id              String   @id @default(cuid())
  userId          String?
  stockCode       String
  stockName       String
  eventSummary    String
  industryTrend   String
  trapProbability Int      @default(0)
  actionSignal    String   @default("HOLD")
  targetPrice     Decimal?
  stopLoss        Decimal?
  logicChain      Json?
  rawData         Json?
  createdAt       DateTime @default(now())
  user            User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([stockCode])
  @@index([actionSignal])
  @@index([createdAt])
}

model StockPriceHistory {
  id            String   @id @default(cuid())
  stockCode     String
  price         Decimal
  volume        Decimal?
  turnover      Decimal?
  highPrice     Decimal?
  lowPrice      Decimal?
  change        Decimal?
  changePercent Decimal?
  timestamp     DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([stockCode])
  @@index([timestamp])
  @@index([stockCode, timestamp])
  @@unique([stockCode, timestamp])
}

model Portfolio {
  id        String   @id @default(cuid())
  userId    String
  stockCode String
  stockName String
  quantity  Int
  avgCost   Decimal
  industry  String?
  notes     String?
  status    String   @default("HOLD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stockCode])
  @@index([userId])
}

model WatchlistGroup {
  id         String   @id @default(cuid())
  userId     String
  name       String
  color      String   @default("#3b82f6")
  stockCodes String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model BacktestResult {
  id        String   @id @default(cuid())
  userId    String
  strategy  String
  stocks    String[]
  startDate DateTime
  endDate   DateTime
  params    Json?
  metrics   Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Post {
  id           String     @id @default(cuid())
  userId       String
  title        String
  content      String
  tags         String[]
  stockCodes   String[]
  likes        Int        @default(0)
  commentCount Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments     Comment[]
  postLikes    PostLike[]

  @@index([userId])
  @@index([createdAt])
}

model Comment {
  id        String    @id @default(cuid())
  userId    String
  postId    String
  content   String
  parentId  String?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("Replies", fields: [parentId], references: [id])
  replies   Comment[] @relation("Replies")

  @@index([postId])
}

model PostLike {
  id     String @id @default(cuid())
  userId String
  postId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}
