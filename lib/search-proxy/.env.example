# 搜索API代理中间层环境变量配置

# ============================================
# 1. 代理配置
# ============================================

# 代理类型：direct（直接连接）、proxy（HTTP代理）、cloud-function（云函数代理）
SEARCH_PROXY_TYPE=cloud-function

# HTTP代理服务器地址（当SEARCH_PROXY_TYPE=proxy时使用）
SEARCH_PROXY_URL=http://your-proxy-server.com:8080

# 云函数代理地址（当SEARCH_PROXY_TYPE=cloud-function时使用）
# 部署到国内服务器（阿里云、腾讯云等）的云函数地址
SEARCH_PROXY_CLOUD_FUNCTION_URL=https://your-cloud-function.com/api/search-proxy

# 代理超时时间（毫秒）
SEARCH_PROXY_TIMEOUT=10000

# ============================================
# 2. 缓存配置
# ============================================

# 缓存启用状态
SEARCH_CACHE_ENABLED=true

# 缓存存活时间（毫秒，默认5分钟）
SEARCH_CACHE_TTL=300000

# 最大缓存条目数
SEARCH_CACHE_MAX_SIZE=1000

# ============================================
# 3. 数据源配置
# ============================================

# 新浪财经API启用状态
SEARCH_SOURCE_SINA_ENABLED=true

# 雪球API启用状态
SEARCH_SOURCE_XUEQIU_ENABLED=true

# 东方财富API启用状态
SEARCH_SOURCE_EASTMONEY_ENABLED=true

# 腾讯财经API启用状态
SEARCH_SOURCE_TENCENT_ENABLED=true

# ============================================
# 4. 安全配置
# ============================================

# API密钥（用于云函数认证，可选）
SEARCH_API_KEY=your-api-key-here

# 允许的源（CORS，逗号分隔）
SEARCH_ALLOWED_ORIGINS=http://localhost:3000,https://alpha-quant-copilot.vercel.app

# ============================================
# 5. 日志配置
# ============================================

# 日志级别：debug, info, warn, error
SEARCH_LOG_LEVEL=info

# ============================================
# 配置说明：
# ============================================

# 1. 开发环境配置：
#    - 使用 direct 模式
#    - 启用所有数据源
#    - 使用本地缓存

# 2. 生产环境配置（Vercel部署）：
#    - 使用 cloud-function 模式
#    - 将云函数部署到国内服务器
#    - 配置云函数地址

# 3. 云函数部署：
#    - 部署到阿里云函数计算、腾讯云函数等
#    - 绑定自定义域名
#    - 配置SSL证书
#    - 设置环境变量

# 4. 测试配置：
#    - 使用 proxy 模式测试代理功能
#    - 禁用缓存进行测试
#    - 设置较低的日志级别