{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/intelligence-feed/generate",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/crons/daily-rollover",
      "schedule": "15 1 * * 1-5"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}